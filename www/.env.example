APP_NAME=Testimonios
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=testimonios
DB_USERNAME=dba
DB_PASSWORD=sql

BROADCAST_DRIVER=log
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_DRIVER=sync

LOG_CHANNEL=daily

# Servicios de Procesamiento (opcional)
# Con Docker Compose usar nombres de contenedor (por defecto)
# Si los servicios corren en el host: http://host.docker.internal:500X (Win/Mac) o http://172.17.0.1:500X (Linux)
TRANSCRIPTION_SERVICE_URL=http://transcription:5000
NER_SERVICE_URL=http://ner:5001
PROCESSING_TIMEOUT=7200

LDAP_ENABLED=true
LDAP_HOST=BDC-DOMINIO.CMH.LOCAL
LDAP_PORT=389
LDAP_BASE_DN=DC=CMH,DC=LOCAL
LDAP_BIND_FORMAT=UPN
LDAP_DOMAIN=CMH.LOCAL
LDAP_NETBIOS=CMH
LDAP_USE_SSL=false
LDAP_USE_STARTTLS=false
LDAP_TIMEOUT=5
